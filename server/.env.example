# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/manobalam

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_byte_hex_secret
JWT_REFRESH_SECRET=replace_with_64_byte_hex_secret

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local:  redis://127.0.0.1:6379
# Render: rediss://<user>:<password>@<host>:6379
REDIS_URL=redis://127.0.0.1:6379

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# https://console.cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Razorpay ─────────────────────────────────────────────────────────────────
# https://dashboard.razorpay.com → Settings → API Keys
# Use test keys (rzp_test_*) for development
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# https://dashboard.razorpay.com → Settings → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── Resend (email) ───────────────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Local development without a verified domain: console
# Production: resend
EMAIL_DELIVERY_MODE=console
# Required for resend mode; use a domain verified in the Resend dashboard.
EMAIL_FROM=ManoBalam <noreply@your-verified-domain.com>

# ─── MSG91 (SMS/OTP) — optional ───────────────────────────────────────────────
# Required only if using SMS-based OTP. Leave blank to skip SMS delivery.
# https://msg91.com/dashboard
MSG91_API_KEY=

# ─── WebRTC TURN Server ───────────────────────────────────────────────────────
# Self-hosted (coturn) or a managed provider (e.g. Twilio, Xirsys)
# Format: turn:<host>:<port>  or  turns:<host>:<port>
TURN_SERVER_URL=turn:your-turn-server-url:3478
TURN_SERVER_USERNAME=your_turn_username
TURN_SERVER_CREDENTIAL=your_turn_password

# ─── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173
